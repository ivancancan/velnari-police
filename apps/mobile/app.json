{
  "expo": {
    "name": "Velnari Field",
    "slug": "velnari-field",
    "version": "1.0.0",
    "scheme": "velnari",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0F172A",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "mx.velnari.field",
      "buildNumber": "4",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Velnari necesita tu ubicación para el despacho.",
        "NSLocationWhenInUseUsageDescription": "Velnari necesita tu ubicación para el despacho.",
        "NSCameraUsageDescription": "Velnari necesita la cámara para adjuntar fotos a incidentes.",
        "NSMicrophoneUsageDescription": "Velnari necesita el micrófono para notas de voz en incidentes.",
        "NSPhotoLibraryUsageDescription": "Velnari necesita acceso a tu galería para adjuntar evidencia a incidentes.",
        "NSPhotoLibraryAddUsageDescription": "Velnari guardará fotos del servicio en tu dispositivo.",
        "NSFaceIDUsageDescription": "Velnari usa Face ID para proteger el acceso a datos operativos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "mx.velnari.field",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Velnari necesita tu ubicación."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6",
          "sounds": []
        }
      ],
      "expo-image-picker",
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication"
    ],
    "newArchEnabled": false,
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3dd106fc-730b-4fe6-a4dc-3d5b30eae3cb"
      }
    },
    "owner": "ivancancan"
  }
}
