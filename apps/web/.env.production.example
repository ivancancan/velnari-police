# ============================================================
# Velnari Web — PRODUCTION environment variables
# ============================================================
# Set these in Vercel / Railway / your deployment platform.
# NEXT_PUBLIC_* vars are embedded in the browser bundle at
# build time — never put secrets here.
# ============================================================

# [REQUIRED] URL of the Velnari API (no trailing slash)
NEXT_PUBLIC_API_URL=https://api.velnari.mx/api

# [REQUIRED] WebSocket URL (same host as API, no /api path)
NEXT_PUBLIC_WS_URL=https://api.velnari.mx

# [optional] Sentry DSN for frontend error tracking
NEXT_PUBLIC_SENTRY_DSN=

# [optional] Build metadata (set automatically by CI)
NEXT_PUBLIC_GIT_SHA=
