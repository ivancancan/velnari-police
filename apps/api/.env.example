# apps/api/.env.example

# ── Database ──────────────────────────────────────────────────────
# Note: Currently uses individual components, not DATABASE_URL connection string
DB_HOST=localhost
DB_PORT=5432
DB_USER=velnari
DB_PASS=velnari_dev
DB_NAME=velnari_dev

# ── Redis ─────────────────────────────────────────────────────────
# Note: Currently uses individual components, not REDIS_URL connection string
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS and WebSocket connections
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── App ───────────────────────────────────────────────────────────
PORT=3001
API_URL=http://localhost:3001
NODE_ENV=development

# ── AWS S3 (leave blank for local disk fallback) ───────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
S3_PUBLIC_URL=

# ── Throttle ──────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── Observability (optional) ──────────────────────────────────────
SENTRY_DSN=
