# ============================================================
# Velnari API — PRODUCTION environment variables
# ============================================================
# Copy to your deployment platform (Railway / ECS / Vercel).
# ALL vars marked [REQUIRED] will crash the server if missing.
# Vars marked [optional] have safe defaults.
#
# Generate secure secrets:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ============================================================

# ── Runtime ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3001                              # [optional] default 3001

# ── Database (PostgreSQL + PostGIS) ─────────────────────────
# [REQUIRED] — set these or the server refuses to start
DB_HOST=your-postgres-host.example.com
DB_PORT=5432                           # [optional] default 5432
DB_USER=velnari_prod
DB_PASS=your-strong-password-here
DB_NAME=velnari_prod

# ── Redis ────────────────────────────────────────────────────
# [REQUIRED] — used for JWT blacklist, BullMQ, cache
REDIS_HOST=your-redis-host.example.com
REDIS_PORT=6379                        # [optional] default 6379

# ── Auth ─────────────────────────────────────────────────────
# [REQUIRED] — minimum 32 random characters each, never share
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=15m                     # [optional] default 15m
JWT_REFRESH_EXPIRES_IN=7d              # [optional] default 7d

# ── CORS ─────────────────────────────────────────────────────
# [REQUIRED] — must NOT contain localhost in production
# Comma-separated, no trailing slash
ALLOWED_ORIGINS=https://app.velnari.mx,https://admin.velnari.mx

# ── AWS S3 (attachments) ─────────────────────────────────────
# [optional] — leave blank to fall back to local disk storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=velnari-attachments-prod
S3_PUBLIC_URL=https://velnari-attachments-prod.s3.us-east-1.amazonaws.com

# ── Observability ────────────────────────────────────────────
# [optional] — strongly recommended for production
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ── Throttle ─────────────────────────────────────────────────
# [optional] — adjust for your expected load
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
